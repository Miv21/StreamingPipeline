        {
          "adHocFilters": [],
          "adHocValuesQuery": "",
          "add_metadata": true,
          "contextWindowSize": "10",
          "editorMode": "builder",
          "extrapolate": true,
          "format": "table",
          "formattedQuery": "/* grafana dashboard='Cripto Live', user=1 */\nSELECT\r\n    symbol AS \"Монеты\",\r\n    argMax(price, timestamp) AS \"Текущая цена\",\r\n    argMax(priceChangePercent, timestamp) AS \"Изменение за 24 часа в (%)\",\r\n    argMax(priceChange, timestamp) AS \"Изменение за 24 часа в ($)\",\r\n    max(toTimeZone(parseDateTimeBestEffort(timestamp), 'Europe/Moscow')) AS \"Последнее обновление\"\r\nFROM default.Prices\r\nGROUP BY symbol\r\nORDER BY \"Монеты\" ASC",
          "interval": "",
          "intervalFactor": 1,
          "nullifySparse": false,
          "query": "SELECT\r\n    symbol AS \"Монеты\",\r\n    argMax(price, timestamp) AS \"Текущая цена\",\r\n    argMax(priceChangePercent, timestamp) AS \"Изменение за 24 часа в (%)\",\r\n    argMax(priceChange, timestamp) AS \"Изменение за 24 часа в ($)\",\r\n    max(toTimeZone(parseDateTimeBestEffort(timestamp), 'Europe/Moscow')) AS \"Последнее обновление\"\r\nFROM default.Prices\r\nGROUP BY symbol\r\nORDER BY \"Монеты\" ASC",
          "refId": "A",
          "round": "0s",
          "skip_comments": true,
          "useWindowFuncForMacros": true
        }
      ],
      "title": "Изменение цены за последние 24 часа",
      "transparent": true,
      "type": "table"
    },
